package com.cinemovie.app;

import android.content.Intent;
import android.content.ActivityNotFoundException;
import android.content.ComponentName;
import com.getcapacitor.JSObject;
import com.getcapacitor.Plugin;
import com.getcapacitor.PluginCall;
import com.getcapacitor.PluginMethod;
import com.getcapacitor.annotation.CapacitorPlugin;

@CapacitorPlugin(name = "SystemCast")
public class SystemCastPlugin extends Plugin {

    @PluginMethod
    public void launchCastSettings(final PluginCall call) {
        getActivity().runOnUiThread(new Runnable() {
            @Override
            public void run() {
                // 1. Try launching the standard Google Cast Dialog overlay (no screen exit)
                try {
                    Intent castIntent = new Intent("com.google.android.gms.cast.ACTION_SHOW_CAST_DIALOG");
                    castIntent.setPackage("com.google.android.gms");
                    castIntent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
                    getActivity().startActivity(castIntent);
                    call.resolve();
                    return;
                } catch (Exception e) {
                    // Google Cast Dialog action not available
                }

                // 2. Try triggering the MediaRouteChooserDialog programmatically using reflection to detect dependencies
                try {
                    Class<?> routeButtonClass = Class.forName("androidx.mediarouter.app.MediaRouteButton");
                    Object routeButton = routeButtonClass.getConstructor(android.content.Context.class).newInstance(getActivity());
                    
                    // Build standard selector for Cast devices
                    Class<?> selectorBuilderClass = Class.forName("androidx.mediarouter.media.MediaRouteSelector$Builder");
                    Object builder = selectorBuilderClass.getConstructor().newInstance();
                    
                    // Add standard cast control category
                    try {
                        Class<?> castControlClass = Class.forName("com.google.android.gms.cast.CastMediaControlIntent");
                        String category = (String) castControlClass.getMethod("categoryForCast", String.class).invoke(null, "CC1AD845"); // Default receiver app ID
                        selectorBuilderClass.getMethod("addControlCategory", String.class).invoke(builder, category);
                    } catch (Exception castEx) {
                        // Fallback to standard generic categories if Cast SDK not linked
                        Class<?> mediaControlClass = Class.forName("androidx.mediarouter.media.MediaControlIntent");
                        String categoryLiveAudio = (String) mediaControlClass.getField("CATEGORY_LIVE_AUDIO").get(null);
                        String categoryLiveVideo = (String) mediaControlClass.getField("CATEGORY_LIVE_VIDEO").get(null);
                        selectorBuilderClass.getMethod("addControlCategory", String.class).invoke(builder, categoryLiveAudio);
                        selectorBuilderClass.getMethod("addControlCategory", String.class).invoke(builder, categoryLiveVideo);
                    }
                    
                    Object selector = selectorBuilderClass.getMethod("build").invoke(builder);
                    routeButtonClass.getMethod("setRouteSelector", Class.forName("androidx.mediarouter.media.MediaRouteSelector")).invoke(routeButton, selector);
                    
                    // Perform click to show routing overlay inside our app
                    routeButtonClass.getMethod("performClick").invoke(routeButton);
                    call.resolve();
                    return;
                } catch (Exception e) {
                    // MediaRouter reflection failed, fallback to system activities
                }

                // 3. Fallback to various native system screen sharing activities
                String[] actions = {
                    "android.settings.CAST_SETTINGS",
                    "android.settings.WIFI_DISPLAY_SETTINGS",
                    "com.samsung.wfd.LAUNCH_WFD_PICKER_DLG",
                    "com.samsung.android.smartmirroring.active",
                    "com.samsung.wfd.wfdpicker",
                    "android.settings.DISPLAY_SETTINGS",
                    "android.settings.WIRELESS_SETTINGS"
                };
                
                for (String action : actions) {
                    try {
                        Intent intent = new Intent(action);
                        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
                        getActivity().startActivity(intent);
                        call.resolve();
                        return;
                    } catch (Exception actionEx) {
                        // Try next action
                    }
                }

                // 4. Try Google Home app launch
                try {
                    Intent homeIntent = getActivity().getPackageManager().getLaunchIntentForPackage("com.google.android.apps.chromecast.app");
                    if (homeIntent != null) {
                        homeIntent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
                        getActivity().startActivity(homeIntent);
                        call.resolve();
                        return;
                    }
                } catch (Exception homeEx) {
                    // Google Home not installed
                }

                // 5. Ultimate fallback to standard general Settings page
                try {
                    Intent intent = new Intent(android.provider.Settings.ACTION_SETTINGS);
                    intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
                    getActivity().startActivity(intent);
                    call.resolve();
                    return;
                } catch (Exception settingsEx) {
                    // General settings also failed
                }
                
                call.reject("Screen mirroring and cast features are not supported on this device.");
            }
        });
    }
}

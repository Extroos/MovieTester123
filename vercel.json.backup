{
  "rewrites": [
    {
      "source": "/hianime/(.*)",
      "destination": "https://server-blue-delta.vercel.app/$1"
    },
    {
      "source": "/proxy",
      "destination": "https://server-blue-delta.vercel.app/proxy"
    },
    {
      "source": "/vidsrc-cc/(.*)",
      "destination": "https://vidsrc.cc/$1"
    }
  ]
}
